# =============================================================================
# Agent / AI-assistant tooling (local state, DO NOT commit)
# Each of these stores per-machine state: permissions, chat snapshots,
# tool-use logs, local overrides. Nothing in here is meant to be public.
# =============================================================================
.claude/
.cursor/
.cursorrules
.cursorignore
.aider*
.continue/
.windsurf/
.codeium/
.roo/
.roomodes

# =============================================================================
# OS cruft
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Model weights + runtime downloads
# Keep the repo lightweight. Models are pulled on first run or via
# `ollama pull` / `python -m piper.download_voices`.
# =============================================================================
*.bin
*.pt
*.pth
*.onnx
*.gguf
*.safetensors
*.ckpt
models/
checkpoints/
openvoice-ckpts/
piper-voices/

# =============================================================================
# Eval harness artifacts (ADR 0001)
# Results are per-run and machine-specific. Commit the harness, not the data.
# =============================================================================
eval/results/*.json
eval/datasets/stt/*.wav
eval/datasets/stt/*.mp3
eval/datasets/stt/*.webm
eval/datasets/stt/*.ogg
eval/datasets/stt/*.flac
eval/datasets/tts/out/

# =============================================================================
