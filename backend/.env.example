# Get your free Groq API key at https://console.groq.com (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# Whisper STT settings
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu

# Kokoro TTS settings
KOKORO_VOICE=af_heart
KOKORO_SPEED=1.0

# LLM settings
LLM_MODEL=llama-3.3-70b-versatile
SYSTEM_PROMPT=You are a helpful voice assistant. Keep responses concise and conversational, ideally under 3 sentences. Be friendly and natural.
