# =============================================================================
# LLM provider — pick one. Defaults to "ollama" so the assistant runs 100%
# offline with no API key. Set LLM_PROVIDER=groq if you want to use the cloud.
# =============================================================================
LLM_PROVIDER=ollama

# --- Ollama (local, free, no key) ---
# Install: https://ollama.com  (then `ollama pull qwen2.5:3b`)
# Or run via docker-compose (the included compose file pulls the model for you).
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# --- Groq (cloud, free tier, requires sign-up) ---
# Get a free key at https://console.groq.com (no credit card needed).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Shared LLM tuning
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=256

# =============================================================================
# Whisper STT (local)
# =============================================================================
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu

# VAD (Phase B.1): Silero VAD inside faster-whisper trims silence before
# decoding. Reduces STT compute on padded audio and prevents silence
# hallucinations. Set WHISPER_VAD_FILTER=false to disable for A/B comparison.
WHISPER_VAD_FILTER=true
WHISPER_VAD_MIN_SILENCE_MS=500
WHISPER_VAD_MIN_SPEECH_MS=150
WHISPER_VAD_SPEECH_PAD_MS=200
WHISPER_VAD_THRESHOLD=0.5

# =============================================================================
# TTS (Phase C): kokoro for English/JA/ZH high-quality; piper for Indic + more.
# =============================================================================
TTS_PROVIDER=kokoro

# Kokoro settings
KOKORO_VOICE=af_heart
KOKORO_SPEED=1.0

# Piper settings (only used when TTS_PROVIDER=piper). See
# docs/design/phase-c-notes.md for voice download instructions.
PIPER_VOICE=
PIPER_DATA_DIR=

# =============================================================================
# System prompt
# =============================================================================
SYSTEM_PROMPT=You are a helpful voice assistant. Keep responses concise and conversational, ideally under 3 sentences. Be friendly and natural.

# =============================================================================
# Phase F hardening
# =============================================================================
# CORS: comma-separated origins in production. "*" is permissive dev default.
ALLOWED_ORIGINS=*

# API key gate. Leave empty for local dev (no auth). Set to a random secret for
# any exposed deployment — clients must send X-API-Key header (or ?api_key=).
API_KEY=

# Rate limit (per API key if set, else per client IP). Set <=0 to disable.
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_CAPACITY=20

# Logging: "text" (default) or "json" for structured logs.
LOG_FORMAT=text
LOG_LEVEL=INFO
